# ============================================================================
# ComplyAI - Variabili d'ambiente (configurare su Vercel Project Settings)
# ============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=https://aicomplyonline.it
NEXT_PUBLIC_APP_NAME=ComplyAI

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID Stripe (uno per ogni piano + cadenza)
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# --- Email (Resend, opzionale per v1) ---
RESEND_API_KEY=
